    "axios": "^1.7.9",
    "telegraf": "^4.16.3",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2"
  }
}
