# === Celo ===
CELO_RPC_URL=https://forno.celo.org
CELO_PRIVATE_KEY=0x...your_private_key_here
CELO_SMART_ACCOUNT_ADDRESS=0x...your_wallet_address_here

# === Hermes LLM (NousResearch) ===
HERMES_API_KEY=sk-...
HERMES_BASE_URL=https://inference-api.nousresearch.com/v1
HERMES_MODEL=hermes-4-70b

# === Redis (Upstash or local) ===
REDIS_URL=redis://localhost:6379

# === Telegram ===
TELEGRAM_BOT_TOKEN=...your_bot_token_from_botfather
TELEGRAM_CHAT_ID=...your_chat_id

# === Filecoin / Lighthouse (audit log) ===
LIGHTHOUSE_API_KEY=...your_lighthouse_api_key

# === Self Protocol (identity verification) ===
SELF_APP_SCOPE=mentoguard
SELF_VERIFICATION_ENDPOINT=https://your-domain.com/api/self/verify
NEXT_PUBLIC_SELF_APP_SCOPE=mentoguard
NEXT_PUBLIC_SELF_VERIFICATION_ENDPOINT=https://your-domain.com/api/self/verify

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_CELO_CHAIN_ID=42220
